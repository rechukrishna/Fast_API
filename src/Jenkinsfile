pipeline {
    agent any

    options {
        timeout(time: 15, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        BACKEND_DIR = 'src/backend'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Start Services') {
            steps {
                dir(env.BACKEND_DIR) {
                    sh 'docker-compose up -d db api'
                    sh 'sleep 30'
                }
            }
        }

        stage('Run API Tests') {
            steps {
                dir(env.BACKEND_DIR) {
                    sh 'docker-compose --profile test run --rm robot-tests'
                }
            }
        }
    }

    post {
        always {
            robot outputPath: "${env.BACKEND_DIR}/tests/results"
            archiveArtifacts artifacts: "${env.BACKEND_DIR}/tests/results/report.html, ${env.BACKEND_DIR}/tests/results/log.html", allowEmptyArchive: true
            dir(env.BACKEND_DIR) {
                sh 'docker-compose down -v'
            }
        }
    }
}
